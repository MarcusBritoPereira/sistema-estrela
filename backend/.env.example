NODE_ENV=development
PORT=3000

# SQL Server (obrigatório)
DATABASE_URL=sqlserver://USER:PASSWORD@HOST:1433;database=DistribuidoraEstrela;encrypt=false;trustServerCertificate=true
DB_USER=
DB_PASSWORD=
DB_SERVER=
DB_NAME=DistribuidoraEstrela
DB_PORT=1433

# Segurança HTTP
CORS_ORIGIN=http://localhost:3001
SWAGGER_ENABLED=true

# Endpoints administrativos de descoberta de banco.
# Mantenha false em produção e habilite somente em ambiente controlado.
DATABASE_DISCOVERY_ENABLED=false

# Autenticação JWT (obrigatório na Fase 1)
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-de-access-token
JWT_REFRESH_SECRET=troque-por-um-segredo-forte-de-refresh-token
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Usuário bootstrap para primeiro acesso.
# Gere o hash com: node -e "const bcrypt=require('bcrypt'); bcrypt.hash('SUA_SENHA', 12).then(console.log)"
AUTH_BOOTSTRAP_EMAIL=admin@empresa.com
AUTH_BOOTSTRAP_PASSWORD_HASH=$2b$12$substitua-pelo-hash-bcrypt
AUTH_BOOTSTRAP_NAME=Administrador
AUTH_BOOTSTRAP_ROLE=ADMIN

# Alternativa para múltiplos usuários:
# AUTH_USERS_JSON=[{"id":"1","email":"diretoria@empresa.com","name":"Diretoria","role":"DIRETORIA","passwordHash":"$2b$12$..."}]

# Produto executivo
EXECUTIVE_MONTHLY_REVENUE_GOAL=0

# Auditoria
AUDIT_LOG_PATH=./audit-logs/audit.jsonl

# Próximas fases
OPENAI_API_KEY=
